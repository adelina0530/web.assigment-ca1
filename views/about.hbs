{{> menu id="about"}}

<section class="ui container segment">

<h2 class="ui center aligned header">
<i class="info circle icon"></i>
About Movie Collection
</h2>

<div class="ui two column stackable grid">



<div class="column">

<div class="ui segment">

<h3 class="ui dividing header">
<i class="film icon"></i>
Application Details
</h3>

<div class="ui list">

<div class="item">
<i class="film icon"></i>
<div class="content">
<strong>App Name</strong>
<div class="description">{{info.appTitle}}</div>
</div>
</div>

<div class="item">
<i class="code branch icon"></i>
<div class="content">
<strong>Version</strong>
<div class="description">{{info.version}}</div>
</div>
</div>

<div class="item">
<i class="map marker alternate icon"></i>
<div class="content">
<strong>Location</strong>
<div class="description">{{info.location}}</div>
</div>
</div>

</div>

</div>


<div class="ui segment">

<h3 class="ui dividing header">
<i class="user icon"></i>
Created By
</h3>

<div class="ui list">

<div class="item">
<i class="user circle icon"></i>
<div class="content">
<div class="header">{{info.creators.0.name}}</div>
<div class="description">
Creator of the Movie Collection application.
</div>
</div>
</div>

<div class="item">
<i class="user plus icon"></i>
<div class="content">
<div class="header">{{info.creators.1.name}}</div>
<div class="description">
Provided with labs and examples to help create thw Movie Collecion easier 
</div>
</div>
</div>

</div>

</div>

</div>




<div class="column">

<div class="ui segment">

<h3 class="ui dividing header">
<i class="map icon"></i>
Location
</h3>

<img src="/mao.jpg" class="ui large rounded image">

</div>

</div>

</div>

</section>